<mujoco model="ur5e_with_robotiq">
  <asset>
    <!-- Use attach-ready submodels and prefixes to avoid name collisions. -->
    <model name="ur5e_model" file="universal_robots_ur5e/ur5e.xml"/>
    <model name="robotiq_model" file="robotiq_2f85/2f85.xml"/>
    <material name="floor_mat" rgba="0.2 0.25 0.3 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="floor_mat"/>

    <body name="ur5e_root">
      <attach model="ur5e_model" body="base" prefix="ur5e_"/>
    </body>

    <!-- Detached placement only to validate loading without name conflicts. -->
    <body name="robotiq_root" pos="0.8 0 0.9">
      <attach model="robotiq_model" body="base_mount" prefix="rq_"/>
    </body>
  </worldbody>
</mujoco>
